# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (root .env is canonical)
.env*

# package manager: this project uses bun (bun.lock is the source of truth).
# Reject npm/yarn lockfiles so they don't drift from bun's resolution.
package-lock.json
yarn.lock

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
